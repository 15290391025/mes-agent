# ManuGent - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM Configuration
# ============================================

# Provider: openai | anthropic | qwen | ollama
# Use ollama for an offline demo, or openai/qwen/anthropic for cloud models.
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_MODEL=gpt-4o

# For local Ollama inference
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:72b

# ============================================
# MES Connection
# ============================================

# MES type: demo | rest | graphql | siemens | digiwin | custom
# demo runs against built-in SMT factory data and needs no external MES.
MES_TYPE=demo
MES_BASE_URL=demo://smt-factory
MES_API_TOKEN=
MES_MAPPING_PATH=

# ============================================
# Database
# ============================================

DATABASE_URL=postgresql://manugent:password@localhost:5432/manugent
REDIS_URL=redis://localhost:6379/0
MEMORY_DB_PATH=data/manugent-memory.sqlite3

# ============================================
# MQTT / OPC UA (Optional)
# ============================================

MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

OPC_UA_ENDPOINT=opc.tcp://localhost:4840

# ============================================
# Application
# ============================================

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
MANUGENT_API_TOKEN=

# API server
API_HOST=0.0.0.0
API_PORT=8000

# MCP server
MCP_PORT=8001

# Web UI
WEB_PORT=3000

# ============================================
# Security
# ============================================

# JWT secret for API authentication
JWT_SECRET=change-me-to-a-random-string

# Enable audit logging
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365

# ============================================
# Edge Runtime
# ============================================

# Enable edge mode (no cloud dependency)
EDGE_MODE=false

# Fallback strategy: local_first | cloud_first | local_only
LLM_FALLBACK_STRATEGY=local_first
